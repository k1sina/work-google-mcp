# Optional overrides — defaults work for most setups.
# Copy to .env (gitignored) if you want to change them.

# Path to the OAuth client secrets JSON downloaded from Google Cloud Console.
# Default: ~/.config/work-google-mcp/client_secrets.json
# WORK_GOOGLE_MCP_CLIENT_SECRETS=/absolute/path/to/client_secrets.json

# Path where the cached OAuth token is persisted after first login.
# Default: ~/.config/work-google-mcp/token.json
# WORK_GOOGLE_MCP_TOKEN_PATH=/absolute/path/to/token.json

# Pin the authenticated email to this address. The server will refuse to start
# if the cached credentials belong to a different account. STRONGLY RECOMMENDED.
# WORK_GOOGLE_MCP_PINNED_EMAIL=you@yourcompany.com
